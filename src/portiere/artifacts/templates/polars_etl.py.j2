def apply_schema_mapping(df: pl.DataFrame) -> pl.DataFrame:
    """Rename source columns to OMOP target columns."""
    existing = {k: v for k, v in COLUMN_MAP.items() if k in df.columns}
    return df.rename(existing)


def apply_concept_mapping(df: pl.DataFrame, source_col: str, target_col: str = "concept_id") -> pl.DataFrame:
    """Map source codes to OMOP concept IDs."""
    return df.with_columns(
        pl.col(source_col).replace(CONCEPT_MAP, default=0).alias(target_col)
    )


