import json
import sys
from pathlib import Path

{% if engine == "polars" %}
import polars as pl
{% elif engine == "pandas" %}
import pandas as pd
{% endif %}


# Validation thresholds
THRESHOLDS = {
    "completeness": {{ thresholds.completeness }},
    "conformance": {{ thresholds.conformance }},
    "plausibility": {{ thresholds.plausibility }},
    "mapping_coverage": {{ thresholds.mapping_coverage }},
}

# Expected concept IDs from mapping
VALID_CONCEPT_IDS = {
{% for mapping in concept_mappings %}
{% if mapping.target_concept_id %}
    {{ mapping.target_concept_id }},
{% endif %}
{% endfor %}
}


def check_completeness(df, required_columns):
    """Check percentage of non-null values in required columns."""
    results = {}
    for col in required_columns:
        if col in df.columns:
{% if engine == "polars" %}
            non_null = df[col].drop_nulls().len()
            total = len(df)
{% else %}
            non_null = df[col].notna().sum()
            total = len(df)
{% endif %}
            results[col] = non_null / total if total > 0 else 0.0
    avg = sum(results.values()) / len(results) if results else 0.0
    return avg, results


def check_conformance(df, concept_id_columns):
    """Check that concept_id columns contain valid values."""
    results = {}
    for col in concept_id_columns:
        if col in df.columns:
{% if engine == "polars" %}
            valid = df.filter(pl.col(col).is_in(list(VALID_CONCEPT_IDS))).height
            total = len(df)
{% else %}
            valid = df[col].isin(VALID_CONCEPT_IDS).sum()
            total = len(df)
{% endif %}
            results[col] = valid / total if total > 0 else 0.0
    avg = sum(results.values()) / len(results) if results else 0.0
    return avg, results


def run_validation(data_path: str, output_path: str = "qa_report.json"):
    """Run all validation checks and generate report."""
{% if engine == "polars" %}
    df = pl.read_parquet(data_path)
{% else %}
    df = pd.read_parquet(data_path)
{% endif %}
    print(f"Validating {len(df)} rows from {data_path}")

    checks = []

    # Completeness
    completeness_score, completeness_detail = check_completeness(
        df, [col for col in df.columns if "id" in col.lower() or "date" in col.lower()]
    )
    checks.append({
        "check_name": "completeness",
        "category": "completeness",
        "passed": completeness_score >= THRESHOLDS["completeness"],
        "score": round(completeness_score, 4),
        "threshold": THRESHOLDS["completeness"],
        "details": completeness_detail,
    })

    # Conformance
    concept_cols = [col for col in df.columns if "concept_id" in col.lower()]
    if concept_cols:
        conformance_score, conformance_detail = check_conformance(df, concept_cols)
        checks.append({
            "check_name": "conformance",
            "category": "conformance",
            "passed": conformance_score >= THRESHOLDS["conformance"],
            "score": round(conformance_score, 4),
            "threshold": THRESHOLDS["conformance"],
            "details": conformance_detail,
        })

    overall_pass = all(c["passed"] for c in checks)

    report = {
        "project": "{{ project_name }}",
        "target_model": "{{ target_model }}",
        "rows_validated": len(df),
        "overall_pass": overall_pass,
        "checks": checks,
    }

    Path(output_path).write_text(json.dumps(report, indent=2, default=str))
    print(f"Validation {'PASSED' if overall_pass else 'FAILED'}")
    print(f"Report written to {output_path}")

    return overall_pass


if __name__ == "__main__":
    data = sys.argv[1] if len(sys.argv) > 1 else "omop_output.parquet"
    report = sys.argv[2] if len(sys.argv) > 2 else "qa_report.json"
    passed = run_validation(data, report)
    sys.exit(0 if passed else 1)
