import pandas as pd


COLUMN_MAP = {
{% for mapping in schema_mappings %}
    "{{ mapping.source_column }}": "{{ mapping.target_column }}",
{% endfor %}
}

CONCEPT_MAP = {
{% for mapping in concept_mappings %}
{% if mapping.target_concept_id %}
    "{{ mapping.source_code }}": {{ mapping.target_concept_id }},
{% endif %}
{% endfor %}
}


def apply_schema_mapping(df: pd.DataFrame) -> pd.DataFrame:
    existing = {k: v for k, v in COLUMN_MAP.items() if k in df.columns}
    return df.rename(columns=existing)


def apply_concept_mapping(df: pd.DataFrame, source_col: str, target_col: str = "concept_id") -> pd.DataFrame:
    df[target_col] = df[source_col].map(CONCEPT_MAP).fillna(0).astype(int)
    return df


