"""
MedMap Generated ETL Script (PySpark)
Project: {{ project_name }}
Target: {{ target_model }}
Generated by MedMap — runs standalone without the SDK.
"""

from pyspark.sql import SparkSession
from pyspark.sql import functions as F
from pyspark.sql.types import IntegerType


COLUMN_MAP = {
{% for mapping in schema_mappings %}
    "{{ mapping.source_column }}": "{{ mapping.target_column }}",
{% endfor %}
}

CONCEPT_MAP = {
{% for mapping in concept_mappings %}
{% if mapping.target_concept_id %}
    "{{ mapping.source_code }}": {{ mapping.target_concept_id }},
{% endif %}
{% endfor %}
}


def apply_schema_mapping(df):
    """Rename source columns to OMOP target columns."""
    for src, tgt in COLUMN_MAP.items():
        if src in df.columns:
            df = df.withColumnRenamed(src, tgt)
    return df


def apply_concept_mapping(df, source_col, target_col="concept_id"):
    """Map source codes to OMOP concept IDs."""
    mapping_expr = F.create_map([F.lit(x) for pair in CONCEPT_MAP.items() for x in pair])
    return df.withColumn(
        target_col,
        F.coalesce(mapping_expr[F.col(source_col)], F.lit(0)).cast(IntegerType())
    )


def main(source_path="{{ source_path }}", output_path="{{ output_path }}"):
    spark = SparkSession.builder.appName("medmap_etl_{{ project_name }}").getOrCreate()

    # Read source
    df = spark.read.csv(source_path, header=True, inferSchema=True)
    print(f"Read {df.count()} rows from {source_path}")

    # Apply schema mapping
    df = apply_schema_mapping(df)

    # Apply concept mappings
{% for col in concept_columns %}
    if "{{ col }}" in df.columns:
        df = apply_concept_mapping(df, "{{ col }}", "{{ col }}_concept_id")
{% endfor %}

    # Write output
    df.write.parquet(output_path, mode="overwrite")
    print(f"ETL complete: rows written to {output_path}")

    spark.stop()


if __name__ == "__main__":
    import sys
    source = sys.argv[1] if len(sys.argv) > 1 else "{{ source_path }}"
    output = sys.argv[2] if len(sys.argv) > 2 else "{{ output_path }}"
    main(source, output)
